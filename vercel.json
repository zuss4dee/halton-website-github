{
  "crons": [
    {
      "path": "/api/cron/process-outbound",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}
